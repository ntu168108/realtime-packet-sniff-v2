{
  "class_name": "Reconnaissance",
  "display_name": "Reconnaissance",
  "description": "Reconnaissance attack — quét mạng (ping sweep, port scan). Đặc trưng: dur ngắn, spkts thấp, sbytes thấp (chỉ probe), ct_state_ttl cao.",
  "keep_columns": [
    "src_mac", "dst_mac", "srcip", "dstip",
    "sport", "dport", "ltime",
    "sttl", "ct_state_ttl", "dttl",
    "sbytes", "dbytes", "smean", "dmean",
    "dur", "spkts", "dpkts",
    "sloss", "dloss",
    "ct_srv_src", "ct_srv_dst", "ct_dst_src_ltm",
    "ct_src_dport_ltm", "ct_dst_sport_ltm",
    "proto", "state", "service"
  ],
  "categorical_mode": {
    "proto": ["tcp", "udp", "icmp"],
    "state": ["INT", "REQ", "CON", "ECO", "RSTO"],
    "service": ["-"]
  },
  "signature": {
    "decisive": [
      { "feature": "spkts",  "op": "<=", "threshold": 5.0,   "attack_median": 2.0,  "normal_median": 14.0 },
      { "feature": "sbytes", "op": "<=", "threshold": 200.0, "attack_median": 100.0, "normal_median": 1684.0 },
      { "feature": "ct_dst_src_ltm", "op": ">=", "threshold": 5.0, "attack_median": 10.0, "normal_median": 2.0 },
      { "feature": "dur",    "op": "<=", "threshold": 1.0,   "attack_median": 0.0,  "normal_median": 0.02 }
    ],
    "support": [
      { "feature": "dbytes", "op": "<=", "threshold": 100.0, "attack_median": 0.0, "normal_median": 2478.0 },
      { "feature": "dpkts",  "op": "<=", "threshold": 3.0,  "attack_median": 0.0, "normal_median": 18.0 },
      { "feature": "smean",  "op": "<=", "threshold": 100.0, "attack_median": 60.0, "normal_median": 73.0 },
      { "feature": "dttl",   "op": "<=", "threshold": 29.0,  "attack_median": 0.0,  "normal_median": 29.0 }
    ]
  },
  "scoring": {
    "weight_decisive": 10,
    "weight_support": 3,
    "min_decisive_required": 2,
    "threshold": 30
  }
}
