# SNIFF Environment Variables
# Copy thành .env và chỉnh giá trị

# Interface
SNIFF_INTERFACE=eth0

# Output directory
SNIFF_OUTPUT=./sniff_data

# Retention days
SNIFF_RETENTION=7

# Log level: DEBUG, INFO, WARNING, ERROR
SNIFF_LOG_LEVEL=INFO

# Log file (for daemon mode)
SNIFF_LOG_FILE=/var/log/sniff/sniff.log
