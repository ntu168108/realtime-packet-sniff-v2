# SNIFF - Cấu hình mẫu
# Copy file này thành config.yaml và chỉnh theo nhu cầu

# ===== Capture =====
capture:
  # Interface mạng để bắt gói tin
  interface: eth0

  # BPF filter (để trống = capture tất cả)
  # Ví dụ: "tcp port 80", "host 192.168.1.1 and port 443"
  bpf_filter: ""

  # Snaplen: số bytes tối đa capture mỗi gói
  # 1518 = full Ethernet, 65535 = max
  snaplen: 65535

  # Promiscuous mode (true = bắt tất cả gói trên mạng)
  promisc: true

  # Buffer profile: low | balanced | fast | max
  buffer_profile: balanced

  # ===== Storage =====
  output:
    # Thư mục gốc cho PCAP files. Phải nằm trong systemd ReadWritePaths=
    # (mặc định /var/lib/sniff-web). /var/lib/sniff-web/sniff_data works out of
    # the box; dùng ./sniff_data sẽ bị "Read-only file system" khi chạy dưới
    # systemd do ProtectSystem=strict.
    base_dir: /var/lib/sniff-web/sniff_data

    # Số ngày giữ file (0 = giữ mãi)
    retention_days: 7

    # Rotation interval (giây) - default 3600 = 1h
    rotate_interval: 3600

    # Max file size trước khi force rotate (bytes) - default 1GB
    max_file_size: 1073741824

    # Gzip compress sau khi rotate
    compress: false

  # ===== Display =====
  display:
    # Filter hiển thị trong TUI (BPF-style)
    display_filter: ""

    # Loại trừ ports (vd: [22] để bỏ SSH)
    exclude_ports: []

    # Số packets cache trong list view
    cache_size: 5000

  # ===== Live mode =====
  live:
    # Chỉ output JSON lines (không TUI) - dùng cho pipe
    enabled: false

  # ===== Modules =====
  modules:
    enabled: []  # Để trống = bật tất cả
    auto_discover: true

  # ===== Performance =====
  performance:
    # Ring buffer size (số packets)
    ring_buffer_size: 65536

    # PCAP batch size (packets/batch)
    batch_size: 256

    # Deep L7 decode (DNS/HTTP/TLS/...) - tốn CPU
    enable_deep_decode: false

    # Periodic GC mỗi N giây
    gc_interval: 30

  # ===== Daemon =====
  daemon:
    pid_file: /tmp/sniff.pid
    log_file: /tmp/sniff.log
    log_level: INFO

# ===== Web GUI (sniff-web.service) =====
# NOTE: `web:` MUST be at the top level (no indent) — sniff-web/web_server.py
# reads it as `c['web']`. Putting it under `capture:` (as in earlier versions)
# silently breaks the login because load_web_config returns defaults only.
web:
  # Bind address (0.0.0.0 = listen on all interfaces; 127.0.0.1 = loopback only)
  bind: 0.0.0.0
  # HTTP port
  port: 8000
  # Admin username (single user)
  username: admin
  # bcrypt hash of admin password. Generate with:
  #   python3 -c "import bcrypt; print(bcrypt.hashpw(b'CHANGE_ME', bcrypt.gensalt()).decode())"
  # The install_web.sh script auto-fills this with a real hash on first install.
  password_hash: "$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH_AT_INSTALL_TIME"
  # JWT signing secret. Auto-generated on first boot if empty/absent.
  jwt_secret: ""
  # JWT expiry in seconds (default 24h)
  jwt_expiry_seconds: 86400
  # Auto-restore last capture on service start (after reboot)
  auto_restore: true
  # Path for last capture config persistence
  persistence_dir: /var/lib/sniff-web

  # ===== External integrations (Dashboard link + /credentials page) =====
  # These values are returned by GET /api/integrations/credentials (JWT auth)
  # and shown on the Dashboard's "Live monitoring" card. Leave a password
  # empty to render it as "not configured" on the UI.
  grafana_url: ""                              # e.g. http://192.168.1.93:3000
  grafana_admin_password: ""                   # shown on /credentials; rotate via grafana.ini
  grafana_dashboard_path: /d/network-ids/network-ids-overview

  integrations:
    clickhouse:
      url: http://localhost:8123              # HTTP interface (read-only SQL)
      username: default
      password: ""
    kafka:
      url: localhost:9092                     # PLAINTEXT bootstrap
      username: ""                            # blank for unauthenticated dev
      password: ""
      protocol: PLAINTEXT

  # ===== Server-side history buffers (for the Dashboard) =====
  alert_ring_size: 20
  rate_history_size: 60        # samples
  rate_history_interval: 5     # seconds per sample → 5 min total window